APP_ENV=development
APP_PORT=8000

# === MySQL（与 Laravel admin 共用同一个库）===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=video_platform
DB_PARAMS=charset=utf8mb4&parseTime=true&loc=Local

# === JWT ===
JWT_SECRET=change-me-in-production
JWT_TTL_HOURS=720

# === CORS ===
CORS_ORIGINS=*

# === WebSocket ===
WS_READ_BUFFER=1024
WS_WRITE_BUFFER=1024
