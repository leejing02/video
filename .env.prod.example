# ============================================================
# 生产环境变量模板
# 拷一份到 .env.prod 后填值，.env.prod 不要进 git
# ============================================================

# === 域名 ===
# 你需要把这两个域名 A 记录解析到服务器 IP
ADMIN_DOMAIN=admin.example.com
API_DOMAIN=api.example.com

# === Let's Encrypt ===
# 证书快过期时 Let's Encrypt 会发邮件提醒到这个邮箱
ACME_EMAIL=admin@example.com

# === Traefik Dashboard 登录凭证 ===
# 生成方法（注意 $ 要写两次转义）：
#   docker run --rm httpd:alpine htpasswd -nbB admin '你的密码' | sed -e 's/\$/\$\$/g'
# 复制输出粘到这里，例如：
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === MySQL ===
DB_NAME=video_platform
DB_USER=video
DB_PASSWORD=please-change-me
DB_ROOT_PASSWORD=please-change-this-too

# === Laravel ===
# 第一次部署时跑：
#   docker compose --env-file .env.prod -f docker-compose.prod.yml run --rm admin php artisan key:generate --show
# 把输出（base64:xxxx）填这里
APP_KEY=

# === Go API JWT ===
# 随机长字符串：openssl rand -hex 32
JWT_SECRET=please-generate-with-openssl-rand-hex-32
JWT_TTL_HOURS=720

# ============================================================
# 数据库备份（每天 03:00 自动 mysqldump 上传 OSS）
# ============================================================
# 阿里云 OSS endpoint，按地域：
#   华东1（杭州）  https://oss-cn-hangzhou.aliyuncs.com
#   华东2（上海）  https://oss-cn-shanghai.aliyuncs.com
#   华北2（北京）  https://oss-cn-beijing.aliyuncs.com
#   香港          https://oss-cn-hongkong.aliyuncs.com
# 也可以填 AWS S3：https://s3.ap-southeast-1.amazonaws.com
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-backup-bucket
OSS_AK=your-access-key-id
OSS_SK=your-access-key-secret

# 保留策略（天）
LOCAL_KEEP_DAYS=7
OSS_KEEP_DAYS=30

# 备份成功 / 失败时调用的 webhook（飞书 / 钉钉 / Slack 都行；不需要可留空）
NOTIFY_WEBHOOK=
